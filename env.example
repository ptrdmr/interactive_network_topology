# Copy to `.env.local` and fill in (get URL + anon/publishable key from Supabase → Settings → API).
# When unset, the app uses localStorage only (no auth, no cloud sync).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Auth: enable Email (magic link) or an OAuth provider in Supabase Dashboard → Authentication.
# Add redirect URLs under Authentication → URL Configuration:
#   - Site URL: https://your-domain.com (or http://localhost:3000 for dev)
#   - Redirect URLs: https://your-domain.com/auth/callback, http://localhost:3000/auth/callback
